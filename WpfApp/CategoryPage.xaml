<Page x:Class="WpfApp.CategoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="780"
      Title="Quản Lý Thể Loại" Background="#ECF0F1">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="🏷️ QUẢN LÝ THỂ LOẠI SÁCH" FontSize="22" FontWeight="Bold" 
                   Foreground="#2C3E50" Margin="0,0,0,15"/>

        <!-- DataGrid -->
        <DataGrid x:Name="dgCategories" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" CanUserAddRows="False" Margin="0,0,0,10"
                  Background="White" BorderBrush="#BDC3C7" BorderThickness="1"
                  SelectionChanged="dgCategories_SelectionChanged"
                  RowBackground="White" AlternatingRowBackground="#F8F9FA"
                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#ECF0F1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding CategoryId}" Width="60"/>
                <DataGridTextColumn Header="Tên Thể Loại" Binding="{Binding CategoryName}" Width="*"/>
                <DataGridTextColumn Header="Mô Tả" Binding="{Binding Description}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Form -->
        <Border Grid.Row="2" Background="White" CornerRadius="5" Padding="15" 
                BorderBrush="#BDC3C7" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,8">
                    <TextBlock Text="Tên thể loại" FontSize="12" Foreground="#7F8C8D" Margin="0,0,0,3"/>
                    <TextBox x:Name="txtCategoryName" FontSize="13" Padding="8,6"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,8">
                    <TextBlock Text="Mô tả" FontSize="12" Foreground="#7F8C8D" Margin="0,0,0,3"/>
                    <TextBox x:Name="txtDescription" FontSize="13" Padding="8,6"/>
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" 
                            HorizontalAlignment="Right" Margin="0,5,0,0">
                    <Button Content="➕ Thêm" Click="btnAdd_Click" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                    <Button Content="✏️ Cập Nhật" Click="btnUpdate_Click" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                    <Button Content="🗑️ Xóa" Click="btnDelete_Click" Style="{StaticResource DangerButton}" Margin="0,0,8,0"/>
                    <Button Content="🧹 Xóa Form" Click="btnClear_Click" Background="#95A5A6" Foreground="White" 
                            FontSize="13" Padding="15,8" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
