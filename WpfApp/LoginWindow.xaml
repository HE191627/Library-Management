<Window x:Class="WpfApp.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Library Elite - Đăng Nhập" Height="500" Width="450"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#2C3E50">
    <Grid>
        <Border Background="White" CornerRadius="10" Margin="40" Padding="30"
                VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
            </Border.Effect>
            <StackPanel>
                <!-- Logo / Title -->
                <TextBlock Text="📚 LIBRARY ELITE" FontSize="26" FontWeight="Bold" 
                           Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="Hệ thống quản lý thư viện" FontSize="12" 
                           Foreground="#95A5A6" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                <!-- Username -->
                <TextBlock Text="Tên đăng nhập" FontSize="13" Foreground="#7F8C8D" Margin="0,0,0,5"/>
                <TextBox x:Name="txtUser" FontSize="14" Padding="10,8" Margin="0,0,0,15"
                         BorderBrush="#BDC3C7" BorderThickness="1"/>

                <!-- Password -->
                <TextBlock Text="Mật khẩu" FontSize="13" Foreground="#7F8C8D" Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtPass" FontSize="14" Padding="10,8" Margin="0,0,0,20"
                             BorderBrush="#BDC3C7" BorderThickness="1"/>

                <!-- Login Button -->
                <Button Content="ĐĂNG NHẬP" Click="btnLogin_Click" Height="40" FontSize="14"
                        FontWeight="Bold" Background="#1ABC9C" Foreground="White" 
                        BorderThickness="0" Cursor="Hand" Margin="0,0,0,10"/>

                <!-- Register Link -->
                <Button Content="Chưa có tài khoản? Đăng ký ngay" Click="btnRegister_Click"
                        Background="Transparent" Foreground="#3498DB" BorderThickness="0"
                        Cursor="Hand" FontSize="12"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
