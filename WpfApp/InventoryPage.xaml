<Page x:Class="WpfApp.InventoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="780"
      Title="Quản Lý Kho Sách" Background="#ECF0F1">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="📖 QUẢN LÝ KHO SÁCH" FontSize="22" FontWeight="Bold" 
                   Foreground="#2C3E50" Margin="0,0,0,15"/>

        <!-- Search & Filter -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="txtSearch" Grid.Column="0" FontSize="13" Padding="8,6" Margin="0,0,10,0"
                     BorderBrush="#BDC3C7" BorderThickness="1" TextChanged="txtSearch_TextChanged">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <VisualBrush Stretch="None" AlignmentX="Left">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="  🔍 Tìm kiếm sách..." Foreground="#BDC3C7" FontSize="13" Margin="5,0,0,0"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>
            <ComboBox x:Name="cbCategoryFilter" Grid.Column="1" FontSize="13" Padding="8,4" 
                      Margin="0,0,10,0" SelectionChanged="cbCategoryFilter_SelectionChanged"
                      DisplayMemberPath="CategoryName"/>
            <Button Content="🔄 Làm mới" Grid.Column="2" Click="btnRefresh_Click"
                    Style="{StaticResource PrimaryButton}"/>
        </Grid>

        <!-- DataGrid -->
        <DataGrid x:Name="dgBooks" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" CanUserAddRows="False" Margin="0,0,0,10"
                  Background="White" BorderBrush="#BDC3C7" BorderThickness="1"
                  SelectionChanged="dgBooks_SelectionChanged"
                  RowBackground="White" AlternatingRowBackground="#F8F9FA"
                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#ECF0F1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding BookId}" Width="45"/>
                <DataGridTextColumn Header="Tên Sách" Binding="{Binding Title}" Width="*"/>
                <DataGridTextColumn Header="ISBN" Binding="{Binding Isbn}" Width="110"/>
                <DataGridTextColumn Header="Tác Giả" Binding="{Binding Author.AuthorName}" Width="130"/>
                <DataGridTextColumn Header="Thể Loại" Binding="{Binding Category.CategoryName}" Width="120"/>
                <DataGridTextColumn Header="Năm XB" Binding="{Binding PublishYear}" Width="65"/>
                <DataGridTextColumn Header="Giá" Binding="{Binding Price, StringFormat=N0}" Width="85"/>
                <DataGridTextColumn Header="SL" Binding="{Binding Quantity}" Width="45"/>
                <DataGridTextColumn Header="Kệ Sách" Binding="{Binding ShelfLocation}" Width="80"/>
                <DataGridTextColumn Header="Trạng Thái" Binding="{Binding Status}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Form Panel -->
        <Border Grid.Row="3" Background="White" CornerRadius="5" Padding="15" BorderBrush="#BDC3C7" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Row 0 -->
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
                    <TextBlock Text="Tên sách" FontSize="11" Foreground="#7F8C8D"/>
                    <TextBox x:Name="txtTitle" FontSize="12" Padding="6,4"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,8,8">
                    <TextBlock Text="ISBN" FontSize="11" Foreground="#7F8C8D"/>
                    <TextBox x:Name="txtISBN" FontSize="12" Padding="6,4"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,8,8">
                    <TextBlock Text="Tác giả" FontSize="11" Foreground="#7F8C8D"/>
                    <ComboBox x:Name="cbAuthor" FontSize="12" Padding="6,2" DisplayMemberPath="AuthorName" SelectedValuePath="AuthorId"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,0,8">
                    <TextBlock Text="Thể loại" FontSize="11" Foreground="#7F8C8D"/>
                    <ComboBox x:Name="cbCategory" FontSize="12" Padding="6,2" DisplayMemberPath="CategoryName" SelectedValuePath="CategoryId"/>
                </StackPanel>

                <!-- Row 1 -->
                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,8">
                    <TextBlock Text="Năm XB" FontSize="11" Foreground="#7F8C8D"/>
                    <TextBox x:Name="txtYear" FontSize="12" Padding="6,4"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,8,8">
                    <TextBlock Text="Giá (VNĐ)" FontSize="11" Foreground="#7F8C8D"/>
                    <TextBox x:Name="txtPrice" FontSize="12" Padding="6,4"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,8,8">
                    <TextBlock Text="Số lượng" FontSize="11" Foreground="#7F8C8D"/>
                    <TextBox x:Name="txtQuantity" FontSize="12" Padding="6,4"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="3" Margin="0,0,8,8">
                    <TextBlock Text="Kệ sách" FontSize="11" Foreground="#7F8C8D"/>
                    <TextBox x:Name="txtShelfLocation" FontSize="12" Padding="6,4"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="4" Margin="0,0,0,8">
                    <TextBlock Text="Trạng thái" FontSize="11" Foreground="#7F8C8D"/>
                    <ComboBox x:Name="cbStatus" FontSize="12" Padding="6,2">
                        <ComboBoxItem Content="Available"/>
                        <ComboBoxItem Content="Damaged"/>
                        <ComboBoxItem Content="Lost"/>
                    </ComboBox>
                </StackPanel>

                <!-- Row 2 - Buttons -->
                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="5" Orientation="Horizontal" 
                            HorizontalAlignment="Right" Margin="0,5,0,0">
                    <Button Content="➕ Thêm Sách" Click="btnAdd_Click" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                    <Button Content="✏️ Cập Nhật" Click="btnUpdate_Click" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                    <Button Content="🗑️ Xóa" Click="btnDelete_Click" Style="{StaticResource DangerButton}" Margin="0,0,8,0"/>
                    <Button Content="🧹 Xóa Form" Click="btnClear_Click" Background="#95A5A6" Foreground="White" 
                            FontSize="13" Padding="15,8" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
