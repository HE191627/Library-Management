<Page x:Class="WpfApp.MemberPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="780"
      Title="Quản Lý Độc Giả" Background="#ECF0F1">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="👥 QUẢN LÝ ĐỘC GIẢ" FontSize="22" FontWeight="Bold" 
                   Foreground="#2C3E50" Margin="0,0,0,15"/>

        <!-- Search -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="txtSearch" Grid.Column="0" FontSize="13" Padding="8,6" Margin="0,0,10,0"
                     BorderBrush="#BDC3C7" BorderThickness="1" TextChanged="txtSearch_TextChanged">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <VisualBrush Stretch="None" AlignmentX="Left">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="  🔍 Tìm kiếm theo tên, email..." Foreground="#BDC3C7" FontSize="13" Margin="5,0,0,0"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>
            <Button Content="🔄 Làm mới" Grid.Column="1" Click="btnRefresh_Click"
                    Style="{StaticResource PrimaryButton}"/>
        </Grid>

        <!-- DataGrid -->
        <DataGrid x:Name="dgMembers" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" CanUserAddRows="False" Margin="0,0,0,10"
                  Background="White" BorderBrush="#BDC3C7" BorderThickness="1"
                  SelectionChanged="dgMembers_SelectionChanged"
                  RowBackground="White" AlternatingRowBackground="#F8F9FA"
                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#ECF0F1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding MemberId}" Width="45"/>
                <DataGridTextColumn Header="Họ Tên" Binding="{Binding FullName}" Width="*"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="170"/>
                <DataGridTextColumn Header="SĐT" Binding="{Binding Phone}" Width="110"/>
                <DataGridTextColumn Header="Địa Chỉ" Binding="{Binding Address}" Width="150"/>
                <DataGridTextColumn Header="Ngày Tham Gia" Binding="{Binding JoinDate, StringFormat=dd/MM/yyyy}" Width="100"/>
                <DataGridTextColumn Header="Trạng Thái" Binding="{Binding Status}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Form -->
        <Border Grid.Row="3" Background="White" CornerRadius="5" Padding="15" 
                BorderBrush="#BDC3C7" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
                    <TextBlock Text="Họ tên" FontSize="11" Foreground="#7F8C8D"/>
                    <TextBox x:Name="txtFullName" FontSize="12" Padding="6,4"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,8,8">
                    <TextBlock Text="Email" FontSize="11" Foreground="#7F8C8D"/>
                    <TextBox x:Name="txtEmail" FontSize="12" Padding="6,4"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,8,8">
                    <TextBlock Text="SĐT" FontSize="11" Foreground="#7F8C8D"/>
                    <TextBox x:Name="txtPhone" FontSize="12" Padding="6,4"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,0,8">
                    <TextBlock Text="Địa chỉ" FontSize="11" Foreground="#7F8C8D"/>
                    <TextBox x:Name="txtAddress" FontSize="12" Padding="6,4"/>
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal" 
                            HorizontalAlignment="Right" Margin="0,5,0,0">
                    <Button Content="➕ Thêm" Click="btnAdd_Click" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                    <Button Content="✏️ Cập Nhật" Click="btnUpdate_Click" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                    <Button Content="🗑️ Xóa" Click="btnDelete_Click" Style="{StaticResource DangerButton}" Margin="0,0,8,0"/>
                    <Button Content="🔒 Khóa/Mở" Click="btnToggleStatus_Click" 
                            Background="#F39C12" Foreground="White" FontSize="13" 
                            Padding="15,8" BorderThickness="0" Cursor="Hand" Margin="0,0,8,0"/>
                    <Button Content="🧹 Xóa Form" Click="btnClear_Click" Background="#95A5A6" Foreground="White" 
                            FontSize="13" Padding="15,8" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
