<Page x:Class="WpfApp.LoanPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="780"
      Title="Quản Lý Mượn Trả" Background="#ECF0F1">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="📋 QUẢN LÝ MƯỢN / TRẢ SÁCH" FontSize="22" FontWeight="Bold" 
                   Foreground="#2C3E50" Margin="0,0,0,15"/>

        <!-- Danh sách phiếu mượn -->
        <DataGrid x:Name="dgLoans" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" CanUserAddRows="False" Margin="0,0,0,10"
                  Background="White" BorderBrush="#BDC3C7" BorderThickness="1"
                  RowBackground="White" AlternatingRowBackground="#F8F9FA"
                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#ECF0F1"
                  SelectionChanged="dgLoans_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã" Binding="{Binding LoanId}" Width="50"/>
                <DataGridTextColumn Header="Độc Giả" Binding="{Binding Member.FullName}" Width="140"/>
                <DataGridTextColumn Header="Ngày Mượn" Binding="{Binding BorrowDate, StringFormat=dd/MM/yyyy}" Width="100"/>
                <DataGridTextColumn Header="Hạn Trả" Binding="{Binding DueDate, StringFormat=dd/MM/yyyy}" Width="100"/>
                <DataGridTextColumn Header="Ngày Trả" Binding="{Binding ReturnDate, StringFormat=dd/MM/yyyy}" Width="100"/>
                <DataGridTextColumn Header="Trạng Thái" Binding="{Binding Status}" Width="90"/>
                <DataGridTextColumn Header="Số Sách" Binding="{Binding LoanDetails.Count}" Width="70"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Chi tiết sách trong phiếu mượn -->
        <Border Grid.Row="2" Background="White" CornerRadius="5" Padding="10" Margin="0,0,0,10"
                BorderBrush="#BDC3C7" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="📚 Chi tiết sách trong phiếu mượn:" FontSize="13" FontWeight="Bold" 
                           Foreground="#2C3E50" Margin="0,0,0,5"/>
                <DataGrid x:Name="dgLoanDetails" AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" MaxHeight="120" Background="White" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Tên Sách" Binding="{Binding Book.Title}" Width="*"/>
                        <DataGridTextColumn Header="Số lượng" Binding="{Binding Quantity}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>

        <!-- Form tạo phiếu mượn mới -->
        <Border Grid.Row="3" Background="White" CornerRadius="5" Padding="15" 
                BorderBrush="#BDC3C7" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Chọn Độc Giả" FontSize="11" Foreground="#7F8C8D"/>
                    <ComboBox x:Name="cbMember" FontSize="12" Padding="6,4" 
                              DisplayMemberPath="FullName" SelectedValuePath="MemberId"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="Chọn Sách (giữ Ctrl để chọn nhiều)" FontSize="11" Foreground="#7F8C8D"/>
                    <ListBox x:Name="lbBooks" Height="60" FontSize="12" SelectionMode="Multiple"
                             DisplayMemberPath="Title"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,10,0" VerticalAlignment="Bottom">
                    <TextBlock Text="Số ngày mượn" FontSize="11" Foreground="#7F8C8D"/>
                    <TextBox x:Name="txtDays" FontSize="12" Padding="6,4" Width="80" Text="14"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Vertical" VerticalAlignment="Bottom">
                    <Button Content="📝 Tạo Phiếu Mượn" Click="btnCreateLoan_Click" 
                            Style="{StaticResource PrimaryButton}" Margin="0,0,0,5"/>
                    <Button Content="✅ Trả Sách" Click="btnReturn_Click" 
                            Background="#27AE60" Foreground="White" FontSize="13" 
                            Padding="15,8" BorderThickness="0" Cursor="Hand" Margin="0,0,0,5"/>
                    <Button Content="🗑️ Xóa Phiếu" Click="btnDeleteLoan_Click" 
                            Style="{StaticResource DangerButton}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
