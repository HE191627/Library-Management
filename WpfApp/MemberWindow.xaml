<Window x:Class="WpfApp.MemberWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Library Elite - Thành Viên" Height="550" Width="800"
        WindowStartupLocation="CenterScreen" Background="#ECF0F1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="20,15">
            <DockPanel>
                <Button Content="🚪 Đăng Xuất" Click="Logout_Click" DockPanel.Dock="Right"
                        Background="#E74C3C" Foreground="White" FontSize="13" Padding="15,8"
                        BorderThickness="0" Cursor="Hand" VerticalAlignment="Center"/>
                <StackPanel>
                    <TextBlock Text="📚 LIBRARY ELITE" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <TextBlock x:Name="txtWelcome" FontSize="13" Foreground="#1ABC9C"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Danh sách sách bạn có thể mượn:" FontSize="15" 
                       FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,10"/>

            <!-- Search + Category Filter -->
            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="txtSearch" Grid.Column="0" FontSize="13" Padding="8,6" Margin="0,0,10,0"
                         BorderBrush="#BDC3C7" BorderThickness="1" TextChanged="txtSearch_TextChanged">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush Stretch="None" AlignmentX="Left">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="  🔍 Tìm sách..." Foreground="#BDC3C7" FontSize="13" Margin="5,0,0,0"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <ComboBox x:Name="cbCategoryFilter" Grid.Column="1" FontSize="13" Padding="8,4"
                          SelectionChanged="cbCategoryFilter_SelectionChanged"
                          DisplayMemberPath="CategoryName"/>
            </Grid>

            <DataGrid x:Name="dgAvailableBooks" Grid.Row="2" AutoGenerateColumns="False" 
                      IsReadOnly="True" CanUserAddRows="False"
                      Background="White" BorderBrush="#BDC3C7" BorderThickness="1"
                      RowBackground="White" AlternatingRowBackground="#F8F9FA"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#ECF0F1">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tên Sách" Binding="{Binding Title}" Width="*"/>
                    <DataGridTextColumn Header="Tác Giả" Binding="{Binding Author.AuthorName}" Width="150"/>
                    <DataGridTextColumn Header="Thể Loại" Binding="{Binding Category.CategoryName}" Width="130"/>
                    <DataGridTextColumn Header="Giá" Binding="{Binding Price, StringFormat=N0}" Width="90"/>
                    <DataGridTextColumn Header="Số lượng" Binding="{Binding Quantity}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>